{
  "permissions": {
    "allow": [
      "Skill(adversary)",
      "Skill(architecture)",
      "Skill(ast)",
      "Skill(contract-design)",
      "Skill(diataxis)",
      "Skill(eng-team)",
      "Skill(nasa-se)",
      "Skill(orchestration)",
      "Skill(pm-pmm)",
      "Skill(problem-solving)",
      "Skill(prompt-engineering)",
      "Skill(red-team)",
      "Skill(saucer-boy)",
      "Skill(saucer-boy-framework-voice)",
      "Skill(test-spec)",
      "Skill(transcript)",
      "Skill(use-case)",
      "Skill(user-experience)",
      "Skill(worktracker)",
      "mcp__memory-keeper__*",
      "mcp__context7__*",
      "mcp__plugin_context7_context7__*",
      "Bash(git push *)",
      "Bash(git stash *)",
      "Bash(grep *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"decision\":\"allow\"}'",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "WebSearch|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PermissionRequest\",\"decision\":{\"behavior\":\"allow\"}}}'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
